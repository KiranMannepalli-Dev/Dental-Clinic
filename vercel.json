{
  "version": 2,

  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/web/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://dental-clinic-f13d.onrender.com"
  },
  "buildCommand": "pnpm --filter web run build"
}
